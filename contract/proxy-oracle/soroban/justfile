    @echo "  just optimize-runtime         Build + optimize runtime WASM"
    @echo "  just optimize-governance      Build + optimize governance WASM"
    @echo "  just optimize                 Build + optimize both WASMs"
    @echo ""
    @echo "GATES:"
    @echo "  just size-check               Enforce 128 KiB size limit on both WASMs"
    @echo "  just budget-check             Run deterministic scenario budget harness"
    @echo "  just release-gate             Full gate: test + size-check + budget-check"
    @echo ""
    @echo "RELEASE ARTIFACTS:"
    @echo "  just release                  Build optimized WASMs + write release-manifest.json"
    @echo "  just dry-run                  Validate artifacts + record dry-run deploy commands"
