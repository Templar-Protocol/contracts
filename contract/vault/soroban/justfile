	fi

# Clean deployment state (keeps identity).
clean-state:
	@echo "Cleaning deployment state..."
	@rm -rf "{{state_dir}}"
	@echo "✓ State cleaned. Identity preserved."

# Full clean (removes everything including build artifacts).
clean-all: clean-state
	@echo "Cleaning build artifacts..."
	@cargo clean --manifest-path "{{root}}/Cargo.toml" 2>/dev/null || true
	@echo "✓ Full clean complete"

# Export deployment info to .env format.
export-env:
	@echo "# Generated by: just export-env"
	@echo "# $(date)"
	@echo ""
	@echo "SOROBAN_NETWORK=${SOROBAN_NETWORK:-{{default_network}}}"
	@echo "SOROBAN_IDENTITY=${SOROBAN_IDENTITY:-{{default_identity}}}"
	@echo "SOROBAN_CONTRACT_ID=$(cat {{state_dir}}/vault_id 2>/dev/null || echo '')"
	@echo "SOROBAN_ASSET_TOKEN=$(cat {{state_dir}}/asset_token_id 2>/dev/null || echo '')"
	@echo "SOROBAN_SHARE_TOKEN=$(cat {{state_dir}}/share_token_id 2>/dev/null || echo '')"
	@echo "SOROBAN_GOVERNANCE=$(cat {{state_dir}}/governance_id 2>/dev/null || echo '')"
	@echo "SOROBAN_ADMIN=$(cat {{state_dir}}/admin_address 2>/dev/null || echo '')"
	@echo "BLEND_ADAPTER_ID=$(cat {{state_dir}}/blend_adapter_id 2>/dev/null || echo '')"
	@echo "BLEND_POOL_ID=$(cat {{state_dir}}/blend_pool_id 2>/dev/null || echo '')"

# Internal: Ensure setup is complete.
_ensure-setup:
	@if ! stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}} >/dev/null 2>&1; then \
		echo "Error: Identity not found. Run 'just setup' first."; \
		exit 1; \
	fi; \
	mkdir -p "{{state_dir}}"; \
	stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}} > "{{state_dir}}/admin_address"

