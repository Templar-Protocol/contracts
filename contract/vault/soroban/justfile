# Get vault state summary.
vault-state:
	@echo "=== Vault State ==="
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}} 2>/dev/null || cat {{state_dir}}/admin_address 2>/dev/null || true)"; \
	if [ -z "$addr" ]; then echo "Error: no identity/admin address available"; exit 1; fi; \
	just proxy-view "$addr" 0 0

# Raw vault proxy view.
proxy-view owner assets="0" shares="0":
	@just invoke proxy_view --owner "{{owner}}" --assets "{{assets}}" --shares "{{shares}}"

# Get admin address.
admin:
	@echo "Curator/governance addresses are returned by proxy-view."
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}} 2>/dev/null || cat {{state_dir}}/admin_address 2>/dev/null || true)"; \
	just proxy-view "$addr" 0 0

# Get asset token address.
asset-token:
	@echo "Asset token is returned by proxy-view."
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}} 2>/dev/null || cat {{state_dir}}/admin_address 2>/dev/null || true)"; \
	just proxy-view "$addr" 0 0

# Get share token address.
share-token:
	@cat "{{state_dir}}/share_token_id" 2>/dev/null || echo "${SOROBAN_SHARE_TOKEN:-}"

supply-queue:
	@echo "Supply queue is returned by proxy-view."
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}} 2>/dev/null || cat {{state_dir}}/admin_address 2>/dev/null || true)"; \
	just proxy-view "$addr" 0 0

# Get total assets under management.
total-assets:
	@echo "Totals are returned by proxy-view."
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}} 2>/dev/null || cat {{state_dir}}/admin_address 2>/dev/null || true)"; \
	just proxy-view "$addr" 0 0

# Get total shares issued.
total-shares:
	@just share-invoke total_supply

# Get idle (unallocated) assets.
idle-assets:
	@echo "Idle assets are returned by proxy-view."
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}} 2>/dev/null || cat {{state_dir}}/admin_address 2>/dev/null || true)"; \
	just proxy-view "$addr" 0 0

# Check if vault is paused.
is-paused:
	@echo "Paused state is returned by proxy-view."
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}} 2>/dev/null || cat {{state_dir}}/admin_address 2>/dev/null || true)"; \
	just proxy-view "$addr" 0 0

# Get share balance for an address.
balance-of addr:
	@just share-invoke balance --account "{{addr}}"

# Get share balance for current identity.
my-balance:
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	just share-invoke balance --account "$addr"

# Preview shares for a deposit amount.
preview-deposit assets:
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	just proxy-view "$addr" "{{assets}}" 0

# Preview assets for a withdrawal amount.
preview-withdraw shares:
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	just proxy-view "$addr" 0 "{{shares}}"

# Get share-token admin.
share-token-admin:
	@just share-invoke admin

# Get share-token pending admin.
share-token-pending-admin:
	@just share-invoke pending_admin

# Get share-token vault binding.
share-token-vault:
	@just share-invoke vault

# Get share-token paused state.
share-token-paused:
	@just share-invoke paused

