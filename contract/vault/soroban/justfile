	@echo ""
	@echo "Vault ID:      $(cat {{state_dir}}/vault_id 2>/dev/null || echo 'not deployed')"
	@echo "Share Token:   $(cat {{state_dir}}/share_token_id 2>/dev/null || echo 'not deployed')"
