set dotenv-load := false

# =============================================================================
# Templar Soroban Vault — Deployment & Testing Justfile
# =============================================================================
#
# QUICK START (testnet):
#   1. just setup              # Build, configure network, create & fund identity
#   2. just deploy-all         # Deploy vault + share token + governance + test token, initialize
#   3. just demo-deposit       # Deposit test tokens
#   4. just demo-withdraw      # Request and execute withdrawal
#
# WITH BLEND INTEGRATION (for yield):
#   1. just setup
#   2. just deploy-all-with-blend <BLEND_POOL_ADDRESS>
#   3. just demo-deposit
#
# PREREQUISITES:
#   - Rust toolchain with wasm32-unknown-unknown target
#   - Stellar CLI: cargo install --locked stellar-cli --features opt
#   - curl (for friendbot funding)
#
# ENVIRONMENT VARIABLES (optional overrides):
#   SOROBAN_NETWORK          Network name (default: testnet)
#   SOROBAN_RPC_URL          RPC endpoint
#   SOROBAN_IDENTITY         Identity name (default: templar)
#   SOROBAN_CONTRACT_ID      Deployed vault contract ID
#   SOROBAN_ASSET_TOKEN      Underlying asset token contract ID
#   SOROBAN_SHARE_TOKEN      Share token contract ID
#   SOROBAN_GOVERNANCE       Governance contract ID
#   SOROBAN_ADMIN            Admin address (defaults to identity)
#   SOROBAN_GOV_TIMLOCK_NS   Governance timelock in nanoseconds
#   BLEND_ADAPTER_ID         Deployed Blend adapter contract ID
#   BLEND_POOL_ID            Blend pool address
#
# =============================================================================

root := justfile_directory() + "/../../.."
wasm_dir := root + "/target/wasm32-unknown-unknown/release-soroban"
debug_wasm := root + "/target/wasm32-unknown-unknown/debug/templar_soroban_runtime.wasm"
wasm_analysis_dir := root + "/target/wasm-analysis"
optimized_wasm := wasm_dir + "/templar_soroban_runtime.optimized.wasm"
deploy_wasm := wasm_dir + "/templar_soroban_runtime.deploy.wasm"
remap_rustflags := "--remap-path-prefix " + root + "=/workspace --remap-path-prefix /home/common/.cargo/registry/src=/cargo-registry --remap-path-prefix /nix/store=/nix-store"
default_wasm := optimized_wasm
blend_adapter_wasm := wasm_dir + "/templar_soroban_blend_adapter.optimized.wasm"
governance_wasm := wasm_dir + "/templar_soroban_governance.optimized.wasm"
share_token_wasm := wasm_dir + "/templar_soroban_share_token.optimized.wasm"
default_friendbot := "https://friendbot.stellar.org"
default_network := "testnet"
default_rpc := "https://soroban-testnet.stellar.org"
default_identity := "templar"

# Path for storing deployment state
state_dir := justfile_directory() + "/.deploy-state"

# =============================================================================
# QUICK SETUP RECIPES
# =============================================================================

# Full setup: build, network config, create identity, fund via friendbot.
setup: build network-init keys-init keys-fund
	@echo ""
	@echo "✓ Setup complete! Next steps:"
	@echo "  1. just deploy-all    # Deploy vault + share token + governance + test token"
	@echo "  2. just demo-deposit  # Run deposit demo"

# Deploy everything: vault + share token + governance + test asset token, then initialize.
deploy-all: _ensure-setup build deploy-test-token deploy deploy-share-token deploy-governance init
	@echo ""
	@echo "✓ Deployment complete!"
	@echo "  Vault:       $(cat {{state_dir}}/vault_id 2>/dev/null || echo 'not found')"
	@echo "  Share Token: $(cat {{state_dir}}/share_token_id 2>/dev/null || echo 'not found')"
	@echo "  Governance:  $(cat {{state_dir}}/governance_id 2>/dev/null || echo 'not found')"
	@echo "  Asset Token: $(cat {{state_dir}}/asset_token_id 2>/dev/null || echo 'not found')"
	@echo ""
	@echo "Run: just demo-deposit"
	@echo "For Blend integration: just deploy-blend-adapter"

# Deploy everything including Blend adapter for yield strategies.
# NOTE: Blend integration requires manual market registration after deployment.
deploy-all-with-blend pool_address: _ensure-setup build build-blend-adapter deploy-test-token deploy deploy-share-token deploy-governance init
	@just deploy-blend-adapter "{{pool_address}}"
	@echo ""
	@echo "✓ Full deployment with Blend adapter complete!"
	@echo "NOTE: Register the Blend adapter as a market in the vault to enable allocation."
	@just status

# =============================================================================
# BUILD
# =============================================================================

# Optimize a built WASM artifact.
# Prefer the non-deprecated `stellar contract build --optimize`; if unavailable
# in the local toolchain (for example missing wasm32v1-none support), fall back
# to `stellar contract optimize` on the prebuilt wasm32-unknown-unknown artifact.
_optimize-wasm package wasm_path:
	@if RUSTFLAGS="${RUSTFLAGS:+$RUSTFLAGS }{{remap_rustflags}}" stellar contract build --manifest-path "{{root}}/Cargo.toml" --package "{{package}}" --optimize --out-dir "{{wasm_dir}}" >/dev/null 2>&1; then \
		:; \
	else \
		stellar contract optimize --wasm "{{wasm_path}}" >/dev/null 2>&1; \
	fi

# Build and optimize the Soroban vault WASM.
build:
	@echo "Building Soroban vault/governance/share-token WASMs..."
	@RUSTFLAGS="${RUSTFLAGS:+$RUSTFLAGS }{{remap_rustflags}}" cargo build --profile release-soroban --target wasm32-unknown-unknown \
		--manifest-path "{{root}}/Cargo.toml" \
		-p templar-soroban-runtime \
		-p templar-soroban-governance \
		-p templar-soroban-share-token
	@just -f "{{justfile_directory()}}/justfile" _optimize-wasm templar-soroban-runtime "{{wasm_dir}}/templar_soroban_runtime.wasm"
	@just -f "{{justfile_directory()}}/justfile" _optimize-wasm templar-soroban-governance "{{wasm_dir}}/templar_soroban_governance.wasm"
	@just -f "{{justfile_directory()}}/justfile" _optimize-wasm templar-soroban-share-token "{{wasm_dir}}/templar_soroban_share_token.wasm"
	@python3 "{{justfile_directory()}}/scripts/strip_contractspec.py" \
		--input "{{optimized_wasm}}" --output "{{deploy_wasm}}"
	@echo "✓ Built optimized: {{optimized_wasm}}"
	@echo "✓ Built deploy:    {{deploy_wasm}}"
	@echo "✓ Built governance: {{governance_wasm}}"
	@echo "✓ Built share token: {{share_token_wasm}}"

# Enforce Soroban vault deploy WASM size budget (default: 128 KiB).
size-budget-check max_bytes="131072": build
	@python3 "{{justfile_directory()}}/scripts/check_wasm_budget.py" \
		--wasm "{{deploy_wasm}}" \
		--max-bytes "{{max_bytes}}"

# Build and optimize the Blend adapter WASM.
build-blend-adapter:
	@echo "Building Blend adapter WASM..."
	@RUSTFLAGS="${RUSTFLAGS:+$RUSTFLAGS }{{remap_rustflags}}" cargo build --profile release-soroban --target wasm32-unknown-unknown \
		--manifest-path "{{root}}/Cargo.toml" -p templar-soroban-blend-adapter
	@just -f "{{justfile_directory()}}/justfile" _optimize-wasm templar-soroban-blend-adapter "{{wasm_dir}}/templar_soroban_blend_adapter.wasm"
	@echo "✓ Built: {{blend_adapter_wasm}}"

# Check the Soroban ERC-4626 proxy crate.
check-4626-proxy:
	@echo "Checking Soroban ERC-4626 proxy crate..."
	@RUSTFLAGS="${RUSTFLAGS:+$RUSTFLAGS }{{remap_rustflags}}" cargo check \
		--manifest-path "{{root}}/Cargo.toml" \
		--target wasm32-unknown-unknown \
		-p templar-4626-proxy-soroban
	@echo "✓ Checked: templar-4626-proxy-soroban"

# Build all WASMs (vault + governance + share token + blend adapter).
build-all: build build-blend-adapter
	@echo "✓ All contracts built"

# Build debug WASM, emit twiggy reports, and print them.
# Usage: just wasm-analyze [rows] [lines]
wasm-analyze rows="250" lines="120":
	@if ! command -v twiggy >/dev/null 2>&1; then \
		echo "Error: twiggy not found. Install with: cargo install twiggy"; \
		exit 1; \
	fi
	@echo "Building debug WASM for analysis..."
	@RUSTFLAGS="${RUSTFLAGS:+$RUSTFLAGS }{{remap_rustflags}}" cargo build --target wasm32-unknown-unknown \
		--manifest-path "{{root}}/Cargo.toml" -p templar-soroban-runtime
	@mkdir -p "{{wasm_analysis_dir}}"
	@twiggy top "{{debug_wasm}}" -n "{{rows}}" > "{{wasm_analysis_dir}}/top.txt"
	@twiggy dominators "{{debug_wasm}}" > "{{wasm_analysis_dir}}/dominators.txt"
	@twiggy monos "{{debug_wasm}}" > "{{wasm_analysis_dir}}/monos.txt"
	@echo "✓ Wrote analysis reports:"
	@echo "  {{wasm_analysis_dir}}/top.txt"
	@echo "  {{wasm_analysis_dir}}/dominators.txt"
	@echo "  {{wasm_analysis_dir}}/monos.txt"
	@echo ""
	@echo "Computing release/optimized WASM sizes..."
	@RUSTFLAGS="${RUSTFLAGS:+$RUSTFLAGS }{{remap_rustflags}}" cargo build --profile release-soroban --target wasm32-unknown-unknown \
		--manifest-path "{{root}}/Cargo.toml" -p templar-soroban-runtime >/dev/null
	@if [ -d "/nix/store/cglbp8zpmbyyvb75ghj6v73n418r9n5n-dbus-1.14.10-lib/lib" ]; then \
		export LD_LIBRARY_PATH="/nix/store/cglbp8zpmbyyvb75ghj6v73n418r9n5n-dbus-1.14.10-lib/lib:${LD_LIBRARY_PATH:-}"; \
	fi; \
	if RUSTFLAGS="${RUSTFLAGS:+$RUSTFLAGS }{{remap_rustflags}}" stellar contract build --manifest-path "{{root}}/Cargo.toml" --package "templar-soroban-runtime" --optimize --out-dir "{{wasm_dir}}" >/dev/null 2>&1; then \
		:; \
	else \
		stellar contract optimize --wasm "{{wasm_dir}}/templar_soroban_runtime.wasm" >/dev/null 2>&1; \
	fi
	@python3 "{{justfile_directory()}}/scripts/print_wasm_sizes.py" \
		--wasm "{{wasm_dir}}/templar_soroban_runtime.wasm" \
		--optimized "{{optimized_wasm}}"
	@just -f "{{justfile_directory()}}/justfile" wasm-analyze-print all "{{lines}}"

# Print wasm analysis reports generated by `wasm-analyze`.
# Usage: just wasm-analyze-print [report] [lines]
# report: top | dominators | monos | all
wasm-analyze-print report="all" lines="120":
	@python3 "{{justfile_directory()}}/scripts/print_wasm_analysis.py" \
		--dir "{{wasm_analysis_dir}}" \
		--report "{{report}}" \
		--lines "{{lines}}"

# Print the default WASM path (optimized artifact with contractspec metadata).
wasm-path:
	@echo "{{default_wasm}}"

# Print the optimized (with contract spec) WASM path.
optimized-wasm-path:
	@echo "{{optimized_wasm}}"

# Print the deploy (spec-stripped) WASM path.
deploy-wasm-path:
	@echo "{{deploy_wasm}}"

# Print the Blend adapter WASM path.
blend-adapter-wasm-path:
	@echo "{{blend_adapter_wasm}}"

# Print the governance WASM path.
governance-wasm-path:
	@echo "{{governance_wasm}}"

# Print the share token WASM path.
share-token-wasm-path:
	@echo "{{share_token_wasm}}"

# =============================================================================
# NETWORK & IDENTITY SETUP
# =============================================================================

# Configure Soroban testnet network (run once).
network-init:
	@network="${SOROBAN_NETWORK:-{{default_network}}}"; \
	rpc="${SOROBAN_RPC_URL:-{{default_rpc}}}"; \
	passphrase="${SOROBAN_NETWORK_PASSPHRASE:-Test SDF Network ; September 2015}"; \
	if ! command -v stellar >/dev/null 2>&1; then \
		echo "Error: stellar CLI not found. Install with:"; \
		echo "  cargo install --locked stellar-cli --features opt"; \
		exit 1; \
	fi; \
	echo "Configuring network: $network"; \
	echo "  RPC: $rpc"; \
	stellar network add --global "$network" --rpc-url "$rpc" --network-passphrase "$passphrase" 2>/dev/null || \
		echo "  (network already configured)"; \
	echo "✓ Network configured"

# Generate a new identity (keypair) and print address.
keys-init name="":
	@name="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	if [ -n "{{name}}" ]; then name="{{name}}"; fi; \
	echo "Generating identity: $name"; \
	if stellar keys address "$name" >/dev/null 2>&1; then \
		echo "  (identity already exists)"; \
	else \
		stellar keys generate --global "$name" --network "${SOROBAN_NETWORK:-{{default_network}}}"; \
	fi; \
	addr="$(stellar keys address "$name")"; \
	echo "✓ Address: $addr"; \
	mkdir -p "{{state_dir}}"; \
	echo "$addr" > "{{state_dir}}/admin_address"

# Fund identity via Friendbot (testnet only).
keys-fund name="":
	@name="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	if [ -n "{{name}}" ]; then name="{{name}}"; fi; \
	friendbot="${SOROBAN_FRIENDBOT_URL:-{{default_friendbot}}}"; \
	addr="$(stellar keys address "$name")"; \
	echo "Funding $addr via Friendbot..."; \
	result=$(curl -sS "$friendbot/?addr=$addr"); \
	if echo "$result" | grep -q "successful"; then \
		echo "✓ Funded successfully"; \
	elif echo "$result" | grep -q "createAccountAlreadyExist"; then \
		echo "✓ Account already funded"; \
	else \
		echo "Friendbot response: $result"; \
	fi

# Show identity address and balance.
keys-show name="":
	@name="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	if [ -n "{{name}}" ]; then name="{{name}}"; fi; \
	addr="$(stellar keys address "$name")"; \
	echo "Identity: $name"; \
	echo "Address:  $addr"; \
	echo ""; \
	echo "To check balance, visit:"; \
	echo "  https://stellar.expert/explorer/testnet/account/$addr"

# Show the secret key for an identity (CAREFUL!).
keys-secret name="":
	@name="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	if [ -n "{{name}}" ]; then name="{{name}}"; fi; \
	echo "Secret key for $name:"; \
	stellar keys show "$name"

# =============================================================================
# DEPLOYMENT
# =============================================================================

# Deploy a test SAC token for the underlying asset (testnet).
deploy-test-token:
	@echo "Deploying test asset token (native XLM wrapper)..."
	@network="${SOROBAN_NETWORK:-{{default_network}}}"; \
	source="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	stellar contract asset deploy \
		--network "$network" \
		--source-account "$source" \
		--asset native 2>/dev/null || true; \
	token_id=$(stellar contract id asset --asset native --network "$network"); \
	if [ -z "$token_id" ]; then \
		echo "Error: failed to resolve native asset contract ID"; \
		exit 1; \
	fi; \
	echo "✓ Asset token: $token_id"; \
	mkdir -p "{{state_dir}}"; \
	echo "$token_id" > "{{state_dir}}/asset_token_id"

# Deploy the vault contract.
deploy:
	@wasm="${SOROBAN_WASM:-{{default_wasm}}}"; \
	network="${SOROBAN_NETWORK:-{{default_network}}}"; \
	source="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	if [ ! -f "$wasm" ]; then \
		echo "Error: WASM not found at $wasm"; \
		echo "Run: just build"; \
		exit 1; \
	fi; \
	echo "Deploying vault contract..."; \
	contract_id=$(stellar contract deploy \
		--wasm "$wasm" \
		--network "$network" \
		--source-account "$source"); \
	if [ -z "$contract_id" ]; then \
		echo "Error: deploy failed — no contract ID returned"; \
		exit 1; \
	fi; \
	echo "✓ Vault deployed: $contract_id"; \
	mkdir -p "{{state_dir}}"; \
	echo "$contract_id" > "{{state_dir}}/vault_id"

# Deploy the standalone share token contract.
deploy-share-token:
	@wasm="${SOROBAN_SHARE_WASM:-{{share_token_wasm}}}"; \
	vault_id="${SOROBAN_CONTRACT_ID:-$(cat {{state_dir}}/vault_id 2>/dev/null)}"; \
	if [ -z "$vault_id" ]; then \
		echo "Error: Vault not deployed. Run 'just deploy' first."; \
		exit 1; \
	fi; \
	if [ ! -f "$wasm" ]; then \
		echo "Error: Share token WASM not found at $wasm"; \
		echo "Run: just build"; \
		exit 1; \
	fi; \
	admin="${SOROBAN_ADMIN:-$(cat {{state_dir}}/admin_address 2>/dev/null)}"; \
	if [ -z "$admin" ]; then \
		admin="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	fi; \
	name="${SOROBAN_SHARE_NAME:-Templar Vault Share}"; \
	symbol="${SOROBAN_SHARE_SYMBOL:-tvSHARE}"; \
	decimals="${SOROBAN_SHARE_DECIMALS:-7}"; \
	network="${SOROBAN_NETWORK:-{{default_network}}}"; \
	source="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	echo "Deploying share token contract..."; \
	echo "  Admin: $admin"; \
	echo "  Vault: $vault_id"; \
	share_id=$(stellar contract deploy \
		--wasm "$wasm" \
		--network "$network" \
		--source-account "$source" \
		-- \
		--admin "$admin" \
		--vault "$vault_id" \
		--name "$name" \
		--symbol "$symbol" \
		--decimals "$decimals"); \
	if [ -z "$share_id" ]; then \
		echo "Error: share token deploy failed"; \
		exit 1; \
	fi; \
	echo "✓ Share token deployed: $share_id"; \
	mkdir -p "{{state_dir}}"; \
	echo "$share_id" > "{{state_dir}}/share_token_id"

# Deploy the governance contract.
deploy-governance:
	@wasm="${SOROBAN_GOV_WASM:-{{governance_wasm}}}"; \
	vault_id="${SOROBAN_CONTRACT_ID:-$(cat {{state_dir}}/vault_id 2>/dev/null)}"; \
	if [ -z "$vault_id" ]; then \
		echo "Error: Vault not deployed. Run 'just deploy' first."; \
		exit 1; \
	fi; \
	if [ ! -f "$wasm" ]; then \
		echo "Error: Governance WASM not found at $wasm"; \
		echo "Run: just build"; \
		exit 1; \
	fi; \
	admin="${SOROBAN_ADMIN:-$(cat {{state_dir}}/admin_address 2>/dev/null)}"; \
	if [ -z "$admin" ]; then \
		admin="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	fi; \
	timelock_ns="${SOROBAN_GOV_TIMELOCK_NS:-0}"; \
	network="${SOROBAN_NETWORK:-{{default_network}}}"; \
	source="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	echo "Deploying governance contract..."; \
	echo "  Admin:    $admin"; \
	echo "  Vault:    $vault_id"; \
	echo "  Timelock: $timelock_ns ns"; \
	gov_id=$(stellar contract deploy \
		--wasm "$wasm" \
		--network "$network" \
		--source-account "$source" \
		-- \
		--admin "$admin" \
		--vault "$vault_id" \
		--timelock_ns "$timelock_ns"); \
	if [ -z "$gov_id" ]; then \
		echo "Error: governance deploy failed"; \
		exit 1; \
	fi; \
	echo "✓ Governance deployed: $gov_id"; \
	mkdir -p "{{state_dir}}"; \
	echo "$gov_id" > "{{state_dir}}/governance_id"

# Initialize the vault contract.
init:
	@contract_id="${SOROBAN_CONTRACT_ID:-$(cat {{state_dir}}/vault_id 2>/dev/null)}"; \
	if [ -z "$contract_id" ]; then \
		echo "Error: No contract ID. Run 'just deploy' first or set SOROBAN_CONTRACT_ID"; \
		exit 1; \
	fi; \
	curator="${SOROBAN_ADMIN:-$(cat {{state_dir}}/admin_address 2>/dev/null)}"; \
	if [ -z "$curator" ]; then \
		curator="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	fi; \
	governance="${SOROBAN_GOVERNANCE:-$(cat {{state_dir}}/governance_id 2>/dev/null)}"; \
	if [ -z "$governance" ]; then \
		governance="$curator"; \
	fi; \
	asset_token="${SOROBAN_ASSET_TOKEN:-$(cat {{state_dir}}/asset_token_id 2>/dev/null)}"; \
	if [ -z "$asset_token" ]; then \
		echo "Error: No asset token. Run 'just deploy-test-token' first or set SOROBAN_ASSET_TOKEN"; \
		exit 1; \
	fi; \
	share_token="${SOROBAN_SHARE_TOKEN:-$(cat {{state_dir}}/share_token_id 2>/dev/null)}"; \
	if [ -z "$share_token" ]; then \
		share_token="$contract_id"; \
	fi; \
	network="${SOROBAN_NETWORK:-{{default_network}}}"; \
	source="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	echo "Initializing vault..."; \
	echo "  Curator:     $curator"; \
	echo "  Governance:  $governance"; \
	echo "  Asset Token: $asset_token"; \
	echo "  Share Token: $share_token"; \
	if ! stellar contract invoke \
		--id "$contract_id" \
		--network "$network" \
		--source-account "$source" \
		-- initialize \
		--curator "$curator" \
		--governance "$governance" \
		--asset_token "$asset_token" \
		--share_token "$share_token"; then \
		echo "Error: vault initialize failed"; \
		exit 1; \
	fi; \
	echo "✓ Vault initialized"

# Extend contract TTL (prevent expiration).
extend-ttl ledgers="100000":
	@contract_id="${SOROBAN_CONTRACT_ID:-$(cat {{state_dir}}/vault_id 2>/dev/null)}"; \
	network="${SOROBAN_NETWORK:-{{default_network}}}"; \
	source="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	echo "Extending TTL for $contract_id by {{ledgers}} ledgers..."; \
	stellar contract extend \
		--id "$contract_id" \
		--network "$network" \
		--source-account "$source" \
		--ledgers-to-extend {{ledgers}}; \
	echo "✓ TTL extended"

# =============================================================================
# BLEND ADAPTER DEPLOYMENT
# =============================================================================
#
# The Blend adapter connects the vault to Blend Protocol pools for yield.
# It uses a constructor pattern (initialized atomically during deployment).
#
# Required: A Blend pool address (get from https://app.blend.capital)
#
# Testnet pools (example - verify current addresses):
#   - USDC Pool: CB...xxx
#   - XLM Pool:  CD...xxx
#
# =============================================================================

# Deploy the Blend adapter contract.
# Requires: vault must be deployed first, pool_address is the Blend pool to use.
deploy-blend-adapter pool_address:
	@wasm="${BLEND_ADAPTER_WASM:-{{blend_adapter_wasm}}}"; \
	if [ ! -f "$wasm" ]; then \
		echo "Error: Blend adapter WASM not found at $wasm"; \
		echo "Run: just build-blend-adapter"; \
		exit 1; \
	fi; \
	vault_id="${SOROBAN_CONTRACT_ID:-$(cat {{state_dir}}/vault_id 2>/dev/null)}"; \
	if [ -z "$vault_id" ]; then \
		echo "Error: Vault not deployed. Run 'just deploy' first."; \
		exit 1; \
	fi; \
	admin="${SOROBAN_ADMIN:-$(cat {{state_dir}}/admin_address 2>/dev/null)}"; \
	if [ -z "$admin" ]; then \
		admin="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	fi; \
	network="${SOROBAN_NETWORK:-{{default_network}}}"; \
	source="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	echo "Deploying Blend adapter..."; \
	echo "  Admin: $admin"; \
	echo "  Vault: $vault_id"; \
	echo "  Pool:  {{pool_address}}"; \
	adapter_id=$(stellar contract deploy \
		--wasm "$wasm" \
		--network "$network" \
		--source-account "$source" \
		-- \
		--admin "$admin" \
		--vault "$vault_id" \
		--pool "{{pool_address}}"); \
	if [ -z "$adapter_id" ]; then \
		echo "Error: deploy failed — no adapter ID returned"; \
		exit 1; \
	fi; \
	echo "✓ Blend adapter deployed: $adapter_id"; \
	mkdir -p "{{state_dir}}"; \
	echo "$adapter_id" > "{{state_dir}}/blend_adapter_id"; \
	echo "{{pool_address}}" > "{{state_dir}}/blend_pool_id"

# Invoke a function on the Blend adapter contract.
blend-invoke *args:
	@adapter_id="${BLEND_ADAPTER_ID:-$(cat {{state_dir}}/blend_adapter_id 2>/dev/null)}"; \
	if [ -z "$adapter_id" ]; then \
		echo "Error: Blend adapter not deployed."; \
		exit 1; \
	fi; \
	network="${SOROBAN_NETWORK:-{{default_network}}}"; \
	source="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	stellar contract invoke \
		--id "$adapter_id" \
		--network "$network" \
		--source-account "$source" \
		-- {{args}}

# Get Blend adapter admin.
blend-adapter-admin:
	@just blend-invoke admin

# Get Blend adapter's configured vault.
blend-adapter-vault:
	@just blend-invoke vault

# Get Blend adapter's configured pool.
blend-adapter-pool:
	@just blend-invoke pool

# Get total assets held in Blend pool via adapter.
# Requires: asset_address is the underlying asset token address.
blend-adapter-total-assets asset_address:
	@just blend-invoke total_assets --asset "{{asset_address}}"

# Update the Blend pool address (admin only).
blend-adapter-set-pool new_pool:
	@admin="${SOROBAN_ADMIN:-$(cat {{state_dir}}/admin_address 2>/dev/null)}"; \
	echo "Updating Blend adapter pool to {{new_pool}}..."; \
	just blend-invoke set_pool --caller "$admin" --pool "{{new_pool}}"; \
	echo "{{new_pool}}" > "{{state_dir}}/blend_pool_id"; \
	echo "✓ Pool updated"

# Update the Blend adapter's vault reference (admin only).
blend-adapter-set-vault new_vault:
	@admin="${SOROBAN_ADMIN:-$(cat {{state_dir}}/admin_address 2>/dev/null)}"; \
	echo "Updating Blend adapter vault to {{new_vault}}..."; \
	just blend-invoke set_vault --caller "$admin" --vault "{{new_vault}}"; \
	echo "✓ Vault updated"

# Rescue stuck assets from the adapter (vault only - for emergencies).
blend-adapter-rescue asset amount receiver:
	@vault_id="${SOROBAN_CONTRACT_ID:-$(cat {{state_dir}}/vault_id 2>/dev/null)}"; \
	echo "Rescuing {{amount}} of {{asset}} to {{receiver}}..."; \
	just blend-invoke rescue \
		--caller "$vault_id" \
		--asset "{{asset}}" \
		--amount "{{amount}}" \
		--receiver "{{receiver}}"; \
	echo "✓ Assets rescued"

# Extend Blend adapter TTL.
blend-adapter-extend-ttl ledgers="100000":
	@adapter_id="${BLEND_ADAPTER_ID:-$(cat {{state_dir}}/blend_adapter_id 2>/dev/null)}"; \
	network="${SOROBAN_NETWORK:-{{default_network}}}"; \
	source="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	echo "Extending TTL for Blend adapter by {{ledgers}} ledgers..."; \
	stellar contract extend \
		--id "$adapter_id" \
		--network "$network" \
		--source-account "$source" \
		--ledgers-to-extend {{ledgers}}; \
	echo "✓ TTL extended"

# Supply tokens from adapter into the Blend pool (admin-only).
# Tokens must already be on the adapter address.
blend-supply asset amount:
	@admin="${SOROBAN_ADMIN:-$(cat {{state_dir}}/admin_address 2>/dev/null)}"; \
	echo "Supplying {{amount}} to Blend pool..."; \
	just blend-invoke supply_balance \
		--caller "$admin" \
		--asset "{{asset}}" \
		--amount "{{amount}}"; \
	echo "✓ Supplied to Blend"

# Withdraw tokens from Blend pool and send to vault (admin-only).
blend-withdraw asset amount:
	@admin="${SOROBAN_ADMIN:-$(cat {{state_dir}}/admin_address 2>/dev/null)}"; \
	echo "Withdrawing {{amount}} from Blend pool to vault..."; \
	just blend-invoke withdraw_to_vault \
		--caller "$admin" \
		--asset "{{asset}}" \
		--amount "{{amount}}"; \
	echo "✓ Withdrawn from Blend to vault"

# Transfer tokens to the adapter address (for funding before blend-supply).
fund-adapter amount:
	@asset="${SOROBAN_ASSET_TOKEN:-$(cat {{state_dir}}/asset_token_id 2>/dev/null)}"; \
	adapter="${BLEND_ADAPTER_ID:-$(cat {{state_dir}}/blend_adapter_id 2>/dev/null)}"; \
	source="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	addr="$(stellar keys address "$source")"; \
	network="${SOROBAN_NETWORK:-{{default_network}}}"; \
	echo "Transferring {{amount}} to adapter ($adapter)..."; \
	stellar contract invoke \
		--id "$asset" \
		--network "$network" \
		--source-account "$source" \
		-- transfer \
		--from "$addr" \
		--to "$adapter" \
		--amount "{{amount}}"; \
	echo "✓ Adapter funded"

# Show Blend adapter status.
blend-adapter-status:
	@echo "=== Blend Adapter Status ==="
	@adapter_id="$(cat {{state_dir}}/blend_adapter_id 2>/dev/null || echo 'not deployed')"; \
	echo "Adapter ID: $adapter_id"
	@if [ -f "{{state_dir}}/blend_adapter_id" ]; then \
		echo "Admin:      $(just blend-invoke admin 2>/dev/null || echo 'error')"; \
		echo "Vault:      $(just blend-invoke vault 2>/dev/null || echo 'error')"; \
		echo "Pool:       $(just blend-invoke pool 2>/dev/null || echo 'error')"; \
	fi

# =============================================================================
# CORE OPERATIONS
# =============================================================================

# Generic contract invocation.
invoke *args:
	@contract_id="${SOROBAN_CONTRACT_ID:-$(cat {{state_dir}}/vault_id 2>/dev/null)}"; \
	if [ -z "$contract_id" ]; then \
		echo "Error: No contract ID. Set SOROBAN_CONTRACT_ID or run 'just deploy'"; \
		exit 1; \
	fi; \
	network="${SOROBAN_NETWORK:-{{default_network}}}"; \
	source="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	stellar contract invoke \
		--id "$contract_id" \
		--network "$network" \
		--source-account "$source" \
		-- {{args}}

# Generic governance contract invocation.
gov-invoke *args:
	@gov_id="${SOROBAN_GOVERNANCE:-$(cat {{state_dir}}/governance_id 2>/dev/null)}"; \
	if [ -z "$gov_id" ]; then \
		echo "Error: No governance ID. Set SOROBAN_GOVERNANCE or run 'just deploy-governance'"; \
		exit 1; \
	fi; \
	network="${SOROBAN_NETWORK:-{{default_network}}}"; \
	source="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	stellar contract invoke \
		--id "$gov_id" \
		--network "$network" \
		--source-account "$source" \
		-- {{args}}

# =============================================================================
# DEPOSIT OPERATIONS
# =============================================================================

# Deposit assets into the vault.
# Usage: just deposit <owner> <receiver> <assets> [min_shares_out]
deposit owner receiver assets min_shares_out="0":
	@echo "Depositing {{assets}} assets..."
	@just invoke deposit_with_min \
		--owner "{{owner}}" \
		--receiver "{{receiver}}" \
		--assets "{{assets}}" \
		--min_shares_out "{{min_shares_out}}"
	@echo "✓ Deposit complete"

# Deposit using the current identity as both owner and receiver.
deposit-self assets min_shares_out="0":
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	echo "Depositing {{assets}} assets to self ($addr)..."; \
	just deposit "$addr" "$addr" "{{assets}}" "{{min_shares_out}}"

# Demo: Deposit 1000 stroops (0.0001 XLM) to the vault.
demo-deposit:
	@echo "=== DEPOSIT DEMO ==="
	@just deposit-self 1000000
	@echo ""
	@just vault-state

# =============================================================================
# WITHDRAWAL OPERATIONS
# =============================================================================

# Request a withdrawal (queues for execution).
# Usage: just request-withdraw <owner> <receiver> <shares> [min_assets_out]
request-withdraw owner receiver shares min_assets_out="0":
	@echo "Requesting withdrawal of {{shares}} shares..."
	@just invoke request_withdraw \
		--owner "{{owner}}" \
		--receiver "{{receiver}}" \
		--shares "{{shares}}" \
		--min_assets_out "{{min_assets_out}}"
	@echo "✓ Withdrawal requested"

# Request withdrawal using current identity.
request-withdraw-self shares min_assets_out="0":
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	echo "Requesting withdrawal of {{shares}} shares to self ($addr)..."; \
	just request-withdraw "$addr" "$addr" "{{shares}}" "{{min_assets_out}}"

# Execute the next pending withdrawal.
execute-withdraw:
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	echo "Executing pending withdrawal..."; \
	just invoke execute_withdraw --caller "$addr"
	@echo "✓ Withdrawal executed"

# Demo: Request withdrawal of 500 shares and execute.
demo-withdraw:
	@echo "=== WITHDRAWAL DEMO ==="
	@echo "Step 1: Request withdrawal"
	@just request-withdraw-self 500000
	@echo ""
	@echo "Step 2: Execute withdrawal"
	@just execute-withdraw
	@echo ""
	@just vault-state

# Atomic withdraw (immediate, requires idle vault with sufficient assets).
# Usage: just withdraw <assets> <receiver> <owner>
withdraw assets receiver owner:
	@echo "Atomic withdrawal of {{assets}} assets..."
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	just invoke withdraw \
		--assets "{{assets}}" \
		--receiver "{{receiver}}" \
		--owner "{{owner}}" \
		--operator "$addr"
	@echo "✓ Withdrawal complete"

# =============================================================================
# ALLOCATOR OPERATIONS (Privileged)
# =============================================================================

# Supply assets to a market.
# Allocate supply to a market via adapter (accounting + transfer + adapter.supply).
allocate-supply market_id amount:
	@contract_id="${SOROBAN_CONTRACT_ID:-$(cat {{state_dir}}/vault_id 2>/dev/null)}"; \
	adapter="${BLEND_ADAPTER_ID:-$(cat {{state_dir}}/blend_adapter_id 2>/dev/null)}"; \
	network="${SOROBAN_NETWORK:-{{default_network}}}"; \
	source="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	addr="$(stellar keys address "$source")"; \
	echo "Allocating {{amount}} to market {{market_id}}..."; \
	stellar contract invoke \
		--id "$contract_id" \
		--network "$network" \
		--source-account "$source" \
		-- allocate_supply \
		--caller "$addr" \
		--adapter "$adapter" \
		--market "{{market_id}}" \
		--amount "{{amount}}"
	@echo "✓ Supply complete"

# Withdraw from a market via adapter (adapter.withdraw + accounting).
allocate-withdraw market_id amount:
	@contract_id="${SOROBAN_CONTRACT_ID:-$(cat {{state_dir}}/vault_id 2>/dev/null)}"; \
	adapter="${BLEND_ADAPTER_ID:-$(cat {{state_dir}}/blend_adapter_id 2>/dev/null)}"; \
	network="${SOROBAN_NETWORK:-{{default_network}}}"; \
	source="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	addr="$(stellar keys address "$source")"; \
	echo "Withdrawing {{amount}} from market {{market_id}}..."; \
	stellar contract invoke \
		--id "$contract_id" \
		--network "$network" \
		--source-account "$source" \
		--instruction-leeway 5000000 \
		-- allocate_withdraw \
		--caller "$addr" \
		--adapter "$adapter" \
		--market "{{market_id}}" \
		--amount "{{amount}}"
	@echo "✓ Withdraw complete"

# Full end-to-end flow:
# deposit -> withdraw -> deposit -> allocate -> withdraw -> allocate(withdraw) -> withdraw
demo-e2e-full:
	@echo "=== FULL E2E FLOW (ON-CHAIN) ==="
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	echo "0) configure supply queue"; \
	just set-supply-queue '[0]'; \
	echo "1) deposit"; \
	just deposit "$addr" "$addr" 2000000 0; \
	echo "2) withdraw (idle)"; \
	just withdraw 200000 "$addr" "$addr"; \
	echo "3) deposit"; \
	just deposit "$addr" "$addr" 1000000 0; \
	echo "4) allocator supplies to market"; \
	just allocate-supply 0 1500000; \
	echo "5) withdraw (idle)"; \
	just withdraw 300000 "$addr" "$addr"; \
	echo "6) user requests withdrawal, allocator withdraws from market"; \
	just request-withdraw "$addr" "$addr" 1500000 0; \
	if just execute-withdraw; then \
		echo "execute_withdraw completed immediately"; \
	else \
		echo "execute_withdraw pending (cooldown/insufficient idle), continuing..."; \
	fi; \
	just allocate-withdraw 0 1000000; \
	echo "7) user withdraws queued request (execute after cooldown)"; \
	if ! just execute-withdraw; then \
		echo "NOTE: execute_withdraw still blocked by cooldown; re-run 'just execute-withdraw' after cooldown window."; \
	fi; \
	echo ""; \
	just vault-state

demo-e2e-finalize:
	@echo "=== FINALIZE QUEUED WITHDRAWAL ==="
	@just execute-withdraw
	@just vault-state

# Full Blend integration e2e (direct adapter invocation):
# deposit -> set supply queue -> supply_to_market -> verify -> withdraw_from_market -> vault withdraw
demo-e2e-blend:
	@echo "=== BLEND INTEGRATION E2E (direct invocation) ==="
	@asset="${SOROBAN_ASSET_TOKEN:-$(cat {{state_dir}}/asset_token_id 2>/dev/null)}"; \
	adapter="${BLEND_ADAPTER_ID:-$(cat {{state_dir}}/blend_adapter_id 2>/dev/null)}"; \
	addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	echo ""; \
	echo "--- Step 1: Register Blend adapter in vault address book ---"; \
	just register-address "$adapter"; \
	sleep 4; \
	echo ""; \
	echo "--- Step 2: Configure supply queue via governance ---"; \
	just set-supply-queue '[0]'; \
	sleep 4; \
	echo ""; \
	echo "--- Step 3: Deposit 2 XLM (20000000 stroops) into vault ---"; \
	just deposit "$addr" "$addr" 20000000 0; \
	sleep 4; \
	echo ""; \
	echo "--- Vault state after deposit ---"; \
	just vault-state; \
	echo ""; \
	echo "--- Step 4: Supply 10000000 to market 0 (accounting + transfer + adapter) ---"; \
	just allocate-supply 0 10000000; \
	sleep 4; \
	echo ""; \
	echo "--- Vault state after supply ---"; \
	just vault-state; \
	echo ""; \
	echo "--- Step 5: Verify Blend position ---"; \
	echo "Blend position:"; \
	just blend-adapter-total-assets "$asset"; \
	echo ""; \
	echo "--- Step 6: Withdraw 10000000 from market 0 (adapter + accounting) ---"; \
	just allocate-withdraw 0 10000000; \
	sleep 4; \
	echo ""; \
	echo "--- Step 7: Withdraw from vault ---"; \
	just withdraw 5000000 "$addr" "$addr"; \
	echo ""; \
	echo "=== Final vault state ==="; \
	just vault-state; \
	echo ""; \
	echo "✓ Blend e2e complete!"

# =============================================================================
# ADMIN OPERATIONS
# =============================================================================

# Pause the vault (admin only).
pause:
	@admin="${SOROBAN_ADMIN:-$(cat {{state_dir}}/admin_address 2>/dev/null)}"; \
	echo "Pausing vault..."; \
	just invoke set_paused --caller "$admin" --paused true; \
	echo "✓ Vault paused"

# Unpause the vault (admin only).
unpause:
	@admin="${SOROBAN_ADMIN:-$(cat {{state_dir}}/admin_address 2>/dev/null)}"; \
	echo "Unpausing vault..."; \
	just invoke set_paused --caller "$admin" --paused false; \
	echo "✓ Vault unpaused"

# Register an address in the vault's address book (curator-only).
# This maps a kernel address index to a Soroban contract/account address.
register-address address:
	@admin="${SOROBAN_ADMIN:-$(cat {{state_dir}}/admin_address 2>/dev/null)}"; \
	echo "Registering address {{address}} in vault..."; \
	just invoke register_address \
		--caller "$admin" \
		--address "{{address}}"; \
	echo "✓ Address registered"

# Set supply queue via governance (submit + accept).
# Requires governance contract deployed with timelock=0 for instant acceptance.
set-supply-queue target_ids_json:
	@admin="${SOROBAN_ADMIN:-$(cat {{state_dir}}/admin_address 2>/dev/null)}"; \
	if [ -z "$admin" ]; then \
		admin="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	fi; \
	echo "Setting supply queue via governance: {{target_ids_json}}"; \
	proposal_id=$(just gov-invoke submit_set_supply_queue \
		--caller "$admin" \
		--target_ids "{{target_ids_json}}" 2>/dev/null | tail -1); \
	echo "  Submitted proposal: $proposal_id"; \
	echo "  Waiting for ledger confirmation..."; \
	sleep 6; \
	just gov-invoke accept --caller "$admin" --proposal_id "$proposal_id"; \
	echo "✓ Supply queue updated"

# Set share token metadata (SEP-41).
set-metadata name="Templar Vault Share" symbol="tvSHARE" decimals="7":
	@echo "Setting share token metadata..."
	@just invoke set_metadata \
		--name "{{name}}" \
		--symbol "{{symbol}}" \
		--decimals "{{decimals}}"
	@echo "✓ Metadata set"

# =============================================================================
# VIEW FUNCTIONS (Read-only)
