# Generic contract invocation.
invoke *args:
	@contract_id="${SOROBAN_CONTRACT_ID:-$(cat {{state_dir}}/vault_id 2>/dev/null)}"; \
	if [ -z "$contract_id" ]; then \
		echo "Error: No contract ID. Set SOROBAN_CONTRACT_ID or run 'just deploy'"; \
		exit 1; \
	fi; \
	network="${SOROBAN_NETWORK:-{{default_network}}}"; \
	source="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	stellar contract invoke \
		--id "$contract_id" \
		--network "$network" \
		--source-account "$source" \
		-- {{args}}

# Invoke the current compact VaultCommand ABI.
vault-execute *args:
	@payload=$(python3 "{{payload_script}}" vault {{args}}); \
	echo "VaultCommand payload: $payload"; \
	just invoke execute --payload "$payload"

# Generic governance contract invocation.
gov-invoke *args:
	@gov_id="${SOROBAN_GOVERNANCE:-$(cat {{state_dir}}/governance_id 2>/dev/null)}"; \
	if [ -z "$gov_id" ]; then \
		echo "Error: No governance ID. Set SOROBAN_GOVERNANCE or run 'just deploy-governance'"; \
		exit 1; \
	fi; \
	network="${SOROBAN_NETWORK:-{{default_network}}}"; \
	source="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	stellar contract invoke \
		--id "$gov_id" \
		--network "$network" \
		--source-account "$source" \
		-- {{args}}

# Generic share-token contract invocation.
share-invoke *args:
	@share_id="${SOROBAN_SHARE_TOKEN:-$(cat {{state_dir}}/share_token_id 2>/dev/null)}"; \
	if [ -z "$share_id" ]; then \
		echo "Error: No share token ID. Set SOROBAN_SHARE_TOKEN or run 'just deploy-share-token'"; \
		exit 1; \
	fi; \
	network="${SOROBAN_NETWORK:-{{default_network}}}"; \
	source="${SOROBAN_IDENTITY:-{{default_identity}}}"; \
	stellar contract invoke \
		--id "$share_id" \
		--network "$network" \
		--source-account "$source" \
		-- {{args}}

# =============================================================================
# DEPOSIT OPERATIONS
# =============================================================================

# Deposit assets into the vault.
# Usage: just deposit <owner> <receiver> <assets> [min_shares_out]
deposit owner receiver assets min_shares_out="0":
	@echo "Depositing {{assets}} assets..."
	@just vault-execute deposit-with-min \
		--owner "{{owner}}" \
		--receiver "{{receiver}}" \
		--assets "{{assets}}" \
		--min-shares-out "{{min_shares_out}}"
	@echo "✓ Deposit complete"

# Deposit using the current identity as both owner and receiver.
deposit-self assets min_shares_out="0":
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	echo "Depositing {{assets}} assets to self ($addr)..."; \
	just deposit "$addr" "$addr" "{{assets}}" "{{min_shares_out}}"

# Demo: Deposit 1000 stroops (0.0001 XLM) to the vault.
demo-deposit:
	@echo "=== DEPOSIT DEMO ==="
	@just deposit-self 1000000
	@echo ""
	@just vault-state

# =============================================================================
# WITHDRAWAL OPERATIONS
# =============================================================================

# Request an async withdrawal (queues shares; does not pull adapter liquidity itself).
# Usage: just request-withdraw <owner> <receiver> <shares> [min_assets_out]
request-withdraw owner receiver shares min_assets_out="0":
	@echo "Requesting withdrawal of {{shares}} shares..."
	@just vault-execute request-withdraw \
		--owner "{{owner}}" \
		--receiver "{{receiver}}" \
		--shares "{{shares}}" \
		--min-assets-out "{{min_assets_out}}"
	@echo "✓ Withdrawal requested"

# Request withdrawal using current identity.
request-withdraw-self shares min_assets_out="0":
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	echo "Requesting withdrawal of {{shares}} shares to self ($addr)..."; \
	just request-withdraw "$addr" "$addr" "{{shares}}" "{{min_assets_out}}"

# Execute the next pending withdrawal. This is keeper/allocator progression.
execute-withdraw:
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	echo "Executing pending withdrawal..."; \
	just vault-execute execute-withdraw --caller "$addr"
	@echo "✓ Withdrawal executed"

# Abort an in-progress withdrawal operation.
abort-withdrawing op_id:
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	echo "Aborting withdrawal operation {{op_id}}..."; \
	just vault-execute abort-withdrawing --caller "$addr" --op-id "{{op_id}}"
	@echo "✓ Withdrawal abort submitted"

# Demo: Request withdrawal of 500 shares and execute.
demo-withdraw:
	@echo "=== WITHDRAWAL DEMO ==="
	@echo "Step 1: Request withdrawal"
	@just request-withdraw-self 500000
	@echo ""
	@echo "Step 2: Execute withdrawal"
	@just execute-withdraw
	@echo ""
	@just vault-state

# Atomic withdraw (ERC-4626-style immediate exit; idle assets only, never queues).
# Usage: just withdraw <assets> <receiver> <owner>
withdraw assets receiver owner:
	@echo "Atomic withdrawal of {{assets}} assets..."
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	just invoke withdraw \
		--assets "{{assets}}" \
		--receiver "{{receiver}}" \
		--owner "{{owner}}" \
		--operator "$addr"
	@echo "✓ Withdrawal complete"

# =============================================================================
# ALLOCATOR OPERATIONS (Privileged)
# =============================================================================

# Supply assets to a market.
# Allocate supply to a market via adapter (accounting + transfer + adapter.supply).
allocate-supply market_id amount:
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	echo "Allocating {{amount}} to market {{market_id}}..."; \
	just vault-execute allocate \
		--caller "$addr" \
		--market "{{market_id}}" \
		--amount "{{amount}}" \
		--supply
	@echo "✓ Supply complete"

# Withdraw from a market via adapter (adapter.withdraw + accounting).
allocate-withdraw market_id amount:
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	echo "Withdrawing {{amount}} from market {{market_id}}..."; \
	just vault-execute allocate \
		--caller "$addr" \
		--market "{{market_id}}" \
		--amount "{{amount}}" \
		--no-supply
	@echo "✓ Withdraw complete"

# Refresh market accounting for a JSON list of market ids.
refresh-markets markets_json:
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	echo "Refreshing markets {{markets_json}}..."; \
	just vault-execute refresh-markets --caller "$addr" --markets '{{markets_json}}'

# Refresh fee anchor and crystallize accrued fees.
refresh-fees:
	@just vault-execute refresh-fees

# Reconcile idle balance with the underlying token balance.
resync-idle-balance:
	@just vault-execute resync-idle-balance

# Extend vault instance storage through the contract command surface.
vault-extend-storage:
	@just vault-execute extend-ttl

# Full end-to-end flow:
# deposit -> withdraw -> deposit -> allocate -> withdraw -> allocate(withdraw) -> withdraw
demo-e2e-full:
	@echo "=== FULL E2E FLOW (ON-CHAIN) ==="
	@addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	adapter="${BLEND_ADAPTER_ID:-$(cat {{state_dir}}/blend_adapter_id 2>/dev/null)}"; \
	if [ -z "$adapter" ]; then echo "Error: deploy Blend adapter first or set BLEND_ADAPTER_ID"; exit 1; fi; \
	echo "0) allow adapter and configure supply queue"; \
	just set-allowed-adapters "[\"$adapter\"]"; \
	just set-supply-queue '[0]' "[\"$adapter\"]"; \
	echo "1) deposit"; \
	just deposit "$addr" "$addr" 2000000 0; \
	echo "2) request and execute idle withdrawal"; \
	just request-withdraw "$addr" "$addr" 200000 0; \
	if ! just execute-withdraw; then \
		echo "NOTE: execute_withdraw may be blocked by cooldown; re-run 'just execute-withdraw' later."; \
	fi; \
	echo "3) deposit again"; \
	just deposit "$addr" "$addr" 1000000 0; \
	echo "4) allocator supplies to market"; \
	just allocate-supply 0 1500000; \
	echo "5) user requests withdrawal, allocator withdraws from market"; \
	just request-withdraw "$addr" "$addr" 1500000 0; \
	if just execute-withdraw; then \
		echo "execute_withdraw completed immediately"; \
	else \
		echo "execute_withdraw pending (cooldown/insufficient idle), continuing..."; \
	fi; \
	just allocate-withdraw 0 1000000; \
	echo "6) user withdraws queued request (execute after cooldown)"; \
	if ! just execute-withdraw; then \
		echo "NOTE: execute_withdraw still blocked by cooldown; re-run 'just execute-withdraw' after cooldown window."; \
	fi; \
	echo ""; \
	just vault-state

demo-e2e-finalize:
	@echo "=== FINALIZE QUEUED WITHDRAWAL ==="
	@just execute-withdraw
	@just vault-state

# Full Blend integration e2e through vault-routed adapter commands.
# deposit -> configure adapter/queue -> allocate -> refresh/verify -> deallocate -> queued withdraw
demo-e2e-blend:
	@echo "=== BLEND INTEGRATION E2E (direct invocation) ==="
	@asset="${SOROBAN_ASSET_TOKEN:-$(cat {{state_dir}}/asset_token_id 2>/dev/null)}"; \
	adapter="${BLEND_ADAPTER_ID:-$(cat {{state_dir}}/blend_adapter_id 2>/dev/null)}"; \
	addr="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	echo ""; \
	echo "--- Step 1: Allow Blend adapter through governance ---"; \
	just set-allowed-adapters "[\"$adapter\"]"; \
	sleep 4; \
	echo ""; \
	echo "--- Step 2: Configure supply queue via governance ---"; \
	just set-supply-queue '[0]' "[\"$adapter\"]"; \
	sleep 4; \
	echo ""; \
	echo "--- Step 3: Deposit 2 XLM (20000000 stroops) into vault ---"; \
	just deposit "$addr" "$addr" 20000000 0; \
	sleep 4; \
	echo ""; \
	echo "--- Vault state after deposit ---"; \
	just vault-state; \
	echo ""; \
	echo "--- Step 4: Supply 10000000 to market 0 (accounting + transfer + adapter) ---"; \
	just allocate-supply 0 10000000; \
	sleep 4; \
	echo ""; \
	echo "--- Vault state after supply ---"; \
	just vault-state; \
	echo ""; \
	echo "--- Step 5: Verify Blend position ---"; \
	echo "Blend position:"; \
	just blend-adapter-total-assets "$asset"; \
	echo ""; \
	echo "--- Step 6: Withdraw 10000000 from market 0 (adapter + accounting) ---"; \
	just allocate-withdraw 0 10000000; \
	sleep 4; \
	echo ""; \
	echo "--- Step 7: Request and execute vault withdrawal ---"; \
	just request-withdraw "$addr" "$addr" 5000000 0; \
	if ! just execute-withdraw; then \
		echo "NOTE: execute_withdraw may be blocked by cooldown; re-run 'just execute-withdraw' later."; \
	fi; \
	echo ""; \
	echo "=== Final vault state ==="; \
	just vault-state; \
	echo ""; \
	echo "✓ Blend e2e complete!"

# =============================================================================
# ADMIN OPERATIONS
# =============================================================================

# Pause the vault (admin only).
pause:
	@admin="${SOROBAN_ADMIN:-$(cat {{state_dir}}/admin_address 2>/dev/null)}"; \
	echo "Pausing vault..."; \
	proposal_id=$(just gov-invoke submit_set_paused --caller "$admin" --paused true 2>/dev/null | tail -1); \
	echo "  Submitted proposal: $proposal_id"; \
	sleep 6; \
	just gov-invoke accept --caller "$admin" --proposal_id "$proposal_id"; \
	echo "✓ Vault paused"

# Unpause the vault (admin only).
unpause:
	@admin="${SOROBAN_ADMIN:-$(cat {{state_dir}}/admin_address 2>/dev/null)}"; \
	echo "Unpausing vault..."; \
	proposal_id=$(just gov-invoke submit_set_paused --caller "$admin" --paused false 2>/dev/null | tail -1); \
	echo "  Submitted proposal: $proposal_id"; \
	sleep 6; \
	just gov-invoke accept --caller "$admin" --proposal_id "$proposal_id"; \
	echo "✓ Vault unpaused"

# Historical helper kept as a guardrail: address-book registration is no longer public ABI.
register-address address:
	@echo "register_address is not exposed by the current vault ABI."
	@echo "Use governance recipes such as set-allowed-adapters and set-supply-queue instead."
	@exit 1

# Set allowed adapters via governance (submit + accept).
set-allowed-adapters adapters_json:
	@admin="${SOROBAN_ADMIN:-$(cat {{state_dir}}/admin_address 2>/dev/null)}"; \
	if [ -z "$admin" ]; then \
		admin="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	fi; \
	echo "Setting allowed adapters via governance: {{adapters_json}}"; \
	proposal_id=$(just gov-invoke submit_set_allowed_adapters \
		--caller "$admin" \
		--adapters '{{adapters_json}}' 2>/dev/null | tail -1); \
	echo "  Submitted proposal: $proposal_id"; \
	sleep 6; \
	just gov-invoke accept --caller "$admin" --proposal_id "$proposal_id"; \
	echo "✓ Allowed adapters updated"

# Set supply queue via governance (submit + accept).
# For instant local acceptance, deploy governance with SOROBAN_GOV_TIMELOCK_NS=0 and
# SOROBAN_ALLOW_ZERO_GOV_TIMELOCK=1.
set-supply-queue entries_json:
	@admin="${SOROBAN_ADMIN:-$(cat {{state_dir}}/admin_address 2>/dev/null)}"; \
	if [ -z "$admin" ]; then \
		admin="$(stellar keys address ${SOROBAN_IDENTITY:-{{default_identity}}})"; \
	fi; \
	echo "Setting supply queue via governance: entries={{entries_json}}"; \
	proposal_id=$(just gov-invoke submit_set_supply_queue \
		--caller "$admin" \
		--entries '{{entries_json}}' 2>/dev/null | tail -1); \
	echo "  Submitted proposal: $proposal_id"; \
	echo "  Waiting for ledger confirmation..."; \
	sleep 6; \
	just gov-invoke accept --caller "$admin" --proposal_id "$proposal_id"; \
	echo "✓ Supply queue updated"

