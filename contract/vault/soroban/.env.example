# Soroban CLI config (testnet defaults)
SOROBAN_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
SOROBAN_FRIENDBOT_URL=https://friendbot.stellar.org

# Soroban identity (configure with soroban CLI and set as source)
SOROBAN_SOURCE=identity
SOROBAN_IDENTITY=identity
SOROBAN_SECRET_KEY=SK...REPLACE_ME

# Contract deployment
SOROBAN_WASM=/absolute/path/to/templar_soroban_runtime.wasm
SOROBAN_CONTRACT_ID=CA...REPLACE_ME

# Vault configuration
SOROBAN_ADMIN=GB...REPLACE_ME
SOROBAN_ASSET_TOKEN=CA...REPLACE_ME
SOROBAN_SHARE_TOKEN=CA...REPLACE_ME

# Share token metadata (SEP-41 fungible token standard)
# Set before calling set_metadata or during initialization.
SHARE_TOKEN_NAME="Templar Vault Share"
SHARE_TOKEN_SYMBOL=tvSHARE
SHARE_TOKEN_DECIMALS=7

# Blend adapter config (optional)
BLEND_ADAPTER_ID=CA...REPLACE_ME
BLEND_POOL_ID=CA...REPLACE_ME
BLEND_FACTORY_ID=CA...REPLACE_ME

# Future integrations (markets/oracles)
MARKET_ADAPTER_ID=CA...REPLACE_ME
ORACLE_ADAPTER_ID=CA...REPLACE_ME
