# Copy to `.env.smoketest` and export, or use `dotenvx run -- ...`.
# This file is for client/vault/smoke_test.py

# ---- Required (integration tests) ----
# Vault account ID (NEAR account where the vault contract is deployed)
VAULT_ACCOUNT=metavault.<your-account>.testnet

# RPC endpoint (FastNEAR recommended)
RPC_URL=https://rpc.testnet.fastnear.com

# Optional: API key for authenticated RPC endpoints
RPC_API_KEY=

# ---- Optional (deposit + donation demo) ----
# Underlying NEP-141 token contract used by the vault
UNDERLYING_TOKEN=usdt.fakes.testnet

# Optional market contract to register/enable supply queue setup
# (used by curator setup path when max_deposit==0)
MARKET_ACCOUNT=usdt.registry.<your-account>.testnet

# ---- Optional roles (enable full happy-path flow) ----
# User credentials: enables deposit (ft_transfer_call Supply) and redeem
USER_ACCOUNT=<your-account>.testnet
USER_SECRET_KEY=ed25519:<your-secret-key>

# Curator credentials: enables market registration, cap submission/acceptance, and supply_queue updates
CURATOR_ACCOUNT=<your-account>.testnet
CURATOR_SECRET_KEY=ed25519:<your-secret-key>

# Allocator credentials: enables reallocate + withdrawal execution routing
ALLOCATOR_ACCOUNT=<your-account>.testnet
ALLOCATOR_SECRET_KEY=ed25519:<your-secret-key>
