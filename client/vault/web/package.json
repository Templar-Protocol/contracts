{
  "name": "@templar/vault-web",
  "version": "0.1.0",
  "description": "Curated web client for Templar Vault - handles deposit, withdraw, and refresh flows with Wallet Selector integration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "generate-types": "npx tsx scripts/generate-types.ts"
  },
  "dependencies": {
    "@near-js/providers": "^2.5.1",
    "@near-js/types": "^2.5.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {},
  "keywords": [
    "near",
    "vault",
    "templar",
    "wallet-selector"
  ],
  "license": "MIT"
}
