  "query": "\n            SELECT\n                id,\n                rpc_method,\n                signer_account_id,\n                idempotency_key,\n                request_fingerprint_hash,\n                request_payload,\n                status as \"status: OperationStatusRow\",\n                created_at,\n                updated_at\n            FROM gateway_operations\n            WHERE status IN ('pending', 'in_progress')\n            ORDER BY created_at ASC\n            ",
