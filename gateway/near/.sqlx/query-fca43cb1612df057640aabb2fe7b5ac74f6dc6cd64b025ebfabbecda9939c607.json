  "query": "\n        SELECT\n            operation_id,\n            step_index,\n            signer_account_id,\n            receiver_id,\n            wait_until,\n            actions,\n            state as \"state: OperationStepStateRow\",\n            tx_hash,\n            signed_transaction,\n            created_at,\n            updated_at\n        FROM gateway_operation_steps\n        WHERE operation_id = $1\n        ORDER BY step_index ASC\n        ",
