  "query": "\nSELECT\n    account_id,\n    operation_key\nFROM\n    \"transaction\"\nWHERE\n    \"status\" = 'pending'::transaction_status\n    AND created_at < NOW() - make_interval(secs => $2)\nORDER BY\n    created_at ASC\nLIMIT\n    $1\n",
