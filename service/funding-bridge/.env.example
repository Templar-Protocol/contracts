# ============================================================================
# Templar Funding Bridge Configuration
# ============================================================================

# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------
PORT=3000

NETWORK=mainnet

# ----------------------------------------------------------------------------
# NEAR Treasury Account (Required)
# ----------------------------------------------------------------------------
NEAR_TREASURY_ACCOUNT=treasury.near
NEAR_TREASURY_KEY=ed25519:YOUR_PRIVATE_KEY_HERE

# NEAR Treasury RPC (optional)
# NEAR_TREASURY_RPC_URL=https://free.rpc.fastnear.com

# ----------------------------------------------------------------------------
# Bridge API
# ----------------------------------------------------------------------------
BRIDGE_API_URL=https://bridge.chaindefuser.com/rpc

# ----------------------------------------------------------------------------
# External Chain Wallets (Optional)
# ----------------------------------------------------------------------------

# Ethereum / EVM Chains (ETH, Arbitrum, Base, Optimism, Polygon)
# ETH_PRIVATE_KEY=0xYOUR_ETH_PRIVATE_KEY_HERE
# ETH_RPC_URL=https://eth.llamarpc.com
# ETH_WITHDRAW_ADDRESS=0xYOUR_ETH_ADDRESS_HERE
# ARBITRUM_WITHDRAW_ADDRESS=0xYOUR_ARBITRUM_ADDRESS_HERE
# BASE_WITHDRAW_ADDRESS=0xYOUR_BASE_ADDRESS_HERE
# OPTIMISM_WITHDRAW_ADDRESS=0xYOUR_OPTIMISM_ADDRESS_HERE
# POLYGON_WITHDRAW_ADDRESS=0xYOUR_POLYGON_ADDRESS_HERE

# Solana
# SOLANA_PRIVATE_KEY=YOUR_BASE58_KEYPAIR_HERE
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# SOLANA_WITHDRAW_ADDRESS=YOUR_SOLANA_ADDRESS_HERE

# Stellar
# STELLAR_SECRET_KEY=SYOUR_STELLAR_SECRET_KEY_HERE
# STELLAR_HORIZON_URL=https://horizon.stellar.org
# STELLAR_WITHDRAW_ADDRESS=GYOUR_STELLAR_ADDRESS_HERE

# NEAR Wallet (for NEAR deposits and withdrawals)
# NEAR_ACCOUNT=external-wallet.near
# NEAR_KEY=ed25519:YOUR_EXTERNAL_WALLET_SECRET_KEY_HERE
# NEAR_RPC_URL=https://rpc.mainnet.near.org

# ----------------------------------------------------------------------------
# Testing & Debugging
# ----------------------------------------------------------------------------
DRY_RUN=false
RUST_LOG=info
RUST_BACKTRACE=1
