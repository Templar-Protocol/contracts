# Templar Funding Bridge Configuration

# ============================================
# SERVER CONFIGURATION
# ============================================

# HTTP server port
PORT=3000

# NEAR network: mainnet or testnet
NETWORK=mainnet

# ============================================
# NEAR CONFIGURATION (REQUIRED)
# ============================================

# Enable NEAR treasury
NEAR_ENABLED=true

# NEAR treasury account that holds funds
NEAR_TREASURY_ACCOUNT=treasury.near

# NEAR signer private key (ed25519:...)
# IMPORTANT: Keep this secret! Never commit to version control
NEAR_SIGNER_KEY=ed25519:YOUR_PRIVATE_KEY_HERE

# NEAR RPC URL (optional, defaults based on network)
# Mainnet: https://rpc.mainnet.near.org
# Testnet: https://rpc.testnet.near.org
# NEAR_RPC_URL=https://free.rpc.fastnear.com

# ============================================
# BRIDGE API CONFIGURATION
# ============================================

# NEAR Intents Bridge API URL
# Default: https://bridge.chaindefuser.com/rpc
BRIDGE_API_URL=https://bridge.chaindefuser.com/rpc

# ============================================
# ETHEREUM CONFIGURATION (OPTIONAL)
# ============================================
# Required only for automated EVM chain deposits
# If not configured, EVM deposits will be disabled

# Ethereum wallet private key for executing deposits
# Supports both formats:
#   - Raw hex: 0x1234...
#   - NEAR format: ed25519:...
# ETH_PRIVATE_KEY=0xYOUR_ETH_PRIVATE_KEY_HERE

# Ethereum RPC URL (optional)
# Default: https://eth.llamarpc.com
# ETH_RPC_URL=https://eth.llamarpc.com

# ============================================
# SOLANA CONFIGURATION (OPTIONAL)
# ============================================
# Required only for automated Solana deposits
# If not configured, Solana deposits will be disabled

# Solana keypair in base58 format
# You can generate with: solana-keygen new
# Or use: solana-keygen pubkey keypair.json | base58 encode
# SOLANA_PRIVATE_KEY=YOUR_BASE58_KEYPAIR_HERE

# Solana RPC URL (optional)
# Default: https://api.mainnet-beta.solana.com
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ============================================
# TESTING & DEBUGGING
# ============================================

# Dry run mode - log actions without executing transactions
# When true, all deposit/withdraw operations are simulated
# Default: false
DRY_RUN=true

# Logging level
# Options: error, warn, info, debug, trace
# Default: info
RUST_LOG=info,templar_funding_bridge=debug

# Enable backtrace for debugging
RUST_BACKTRACE=1

# ============================================
# CHAIN PRIORITY (OPTIONAL)
# ============================================

# NEAR chain priority (0 = highest)
# Used when multiple chains can fulfill a deposit
# Default: 0
# NEAR_PRIORITY=0

# ============================================
# SECURITY NOTES
# ============================================
#
# 1. NEVER commit this file with real private keys
# 2. Use environment variable management tools in production:
#    - HashiCorp Vault
#    - AWS Secrets Manager
#    - Docker secrets
#    - Kubernetes secrets
#
# 3. For production deployments:
#    - Use separate hot wallet with limited funds
#    - Enable monitoring and alerts
#    - Run behind reverse proxy with TLS
#    - Implement rate limiting
#    - Regular key rotation
#
# 4. Test thoroughly in dry-run mode before production use

# ============================================
# EXAMPLE USAGE
# ============================================
#
# Start in dry-run mode (recommended for testing):
#   ./funding-bridge --dry-run
#
# Start with custom config:
#   ./funding-bridge --port 3000 --network mainnet
#
# Start with all features:
#   ./funding-bridge \
#     --network mainnet \
#     --near-enabled \
#     --near-treasury-account treasury.near \
#     --near-signer-key "ed25519:..."
#
# Use Docker:
#   docker run -d --env-file .env templar-funding-bridge
