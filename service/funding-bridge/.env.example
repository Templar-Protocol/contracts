# Templar Funding Bridge Configuration

# Server
PORT=3000
NETWORK=mainnet

# NEAR (Required)
NEAR_ACCOUNT=treasury.near
NEAR_SIGNER_KEY=ed25519:YOUR_PRIVATE_KEY_HERE

# Bridge API
BRIDGE_API_URL=https://bridge.chaindefuser.com/rpc

# NEAR RPC (Optional - defaults: mainnet=rpc.mainnet.near.org, testnet=rpc.testnet.near.org)
# NEAR_RPC_URL=https://free.rpc.fastnear.com

# Ethereum (Optional)
# ETH_PRIVATE_KEY=0xYOUR_ETH_PRIVATE_KEY_HERE
# ETH_RPC_URL=https://eth.llamarpc.com
# ETH_WITHDRAW_ADDRESS=0xYOUR_ETH_ADDRESS_HERE

# Solana (Optional)
# SOLANA_PRIVATE_KEY=YOUR_BASE58_KEYPAIR_HERE
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# SOLANA_WITHDRAW_ADDRESS=YOUR_SOLANA_ADDRESS_HERE

# Stellar (Optional)
# STELLAR_SECRET_KEY=SYOUR_STELLAR_SECRET_KEY_HERE
# STELLAR_HORIZON_URL=https://horizon.stellar.org
# STELLAR_NETWORK=mainnet
# STELLAR_WITHDRAW_ADDRESS=GYOUR_STELLAR_ADDRESS_HERE
#
# IMPORTANT: Stellar withdrawal address must be:
# - Activated on Stellar network (minimum 1 XLM balance)
# - Have trustline established for the token you're withdrawing (e.g., USDC)
# - Use correct network (mainnet vs testnet)

# Testing & Debugging
DRY_RUN=false
RUST_LOG=info
RUST_BACKTRACE=1
