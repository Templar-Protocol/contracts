# Templar Accumulator configuration
#
# Copy this file to .env and edit the values before running:
#   cp .env.example .env

# Required
SIGNER_ACCOUNT_ID="accumulator.near"

# Provide either SIGNER_KEY or SIGNER_KEY_FILE
SIGNER_KEY=""
# SIGNER_KEY_FILE="/absolute/path/to/accumulator.key"

# Optional
NETWORK="mainnet"
REGISTRIES_ACCOUNT_IDS="v1.tmplr.near"
# RPC_URL="https://free.rpc.fastnear.com"
TIMEOUT="60"
INTERVAL="600"
STATIC_INTERVAL="86400"
REGISTRY_REFRESH_INTERVAL="3600"
CONCURRENCY="4"

# Logging
RUST_LOG="info,templar_accumulator=debug"
RUST_BACKTRACE="1"
